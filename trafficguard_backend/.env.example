# ── Google Gemini (REQUIRED for /analyze) ────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_VISION_MODEL=gemini-1.5-flash

# ── MapMyIndia / Mappls ───────────────────────────────────────────────────────
# STATIC key  → use MAPMYINDIA_REST_KEY  (recommended if you have it)
# OAuth2 keys → use MAPMYINDIA_CLIENT_ID + MAPMYINDIA_CLIENT_SECRET
MAPMYINDIA_REST_KEY=your-static-mappls-key-here
MAPMYINDIA_CLIENT_ID=
MAPMYINDIA_CLIENT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=trafficguard.db

# ── Business-logic knobs ─────────────────────────────────────────────────────
AUTO_CHALLAN_CONFIDENCE_THRESHOLD=0.92
DEDUP_WINDOW_MINUTES=10
REOFFENDER_WINDOW_DAYS=7
LOW_LIGHT_THRESHOLD=60
